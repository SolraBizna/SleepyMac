.a.o  ŲÆ  .a  {ŌĆóMondoBuildŌĆó}
	{Asm} {depDir}{default}.a -o {targDir}{default}.a.o {AOptions}

.c.o  ŲÆ  .c  {ŌĆóMondoBuildŌĆó}
	{C} {depDir}{default}.c -o {targDir}{default}.c.o {COptions}

"SleepyMac"  ŲÆŲÆ  {InitObjFiles} {LibFiles-68K} {ŌĆóMondoBuildŌĆó}
	ILink Ōłé
		-o {Targ} Ōłé
		{InitObjFiles} Ōłé
		{LibFiles-68K} Ōłé
		{Sym-68K} Ōłé
		-mf -d Ōłé
		-m INIT Ōłé
		-t 'cdev' Ōłé
		-c '├¤l├¼' Ōłé
		-model near Ōłé
		-sg "SleepyMac" Ōłé
		-rt 'INIT=-4064' Ōłé
		-state rewrite Ōłé
		-compact -pad 0
	If "{Sym-68K}" =~ /-sym Ōēł[nNuU]Ōēł/
		ILinkToSYM {Targ}.INIT61472.NJ -mf -sym 3.2 -c 'sade'
	End
