MakeFile		= "MakeFile"
ŌĆóMondoBuildŌĆó	= {MAKEFILE} # make it blank to avoid rebuilds when the makefile is modified

ObjDir          = :Objects:
Includes        = 

Sym-68K         = -sym off

AOptions        = {Includes} {Sym-68K} -model near 
COptions        = {Includes} {Sym-68K} -model near -b -opt space -proto strict

InitSrcFiles	= Ōłé
				  init.c
InitObjFiles	= Ōłé
				  "{ObjDir}init.c.o" Ōłé
				  "ShowINIT.a.o" # NOT in ObjDir!
